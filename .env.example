# ============================================================================
#  ШАБЛОН ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
#  Скопируй в .env и заполни своими значениями.
#  cp .env.example .env
# ============================================================================

# === GigaChat (Сбер) ===
# Получить: https://developers.sber.ru/portal/products/gigachat-api
GIGACHAT_KEY=
AI_PROVIDER=gigachat

# === Альтернативно — OpenAI ===
# OPENAI_KEY=sk-...
# AI_PROVIDER=openai

# === ВКонтакте (нотификации лидов) ===
# Получить токен: https://vkhost.github.io/ (пользовательский) или
# в настройках сообщества: Управление → Работа с API → Создать ключ
VK_TOKEN=
VK_USER_ID=

# === Безопасность ===
# СГЕНЕРИРУЙ свой длинный секрет для КАЖДОГО (не переиспользуй):
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# JWT_SECRET — обязателен, иначе не будут работать авторизация и токены.
JWT_SECRET=
ADMIN_TOKEN=
SUPERADMIN_MASTER_TOKEN=

# === База данных (PostgreSQL) ===
# Используются docker-compose для контейнера db и строки подключения API.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=mitia

# === YandexGPT (альтернативная модель ассистента) ===
# Нужны, если в тарифах доступна модель yandexgpt.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# === Сайт ===
SITE_URL=https://example.com
PUBLIC_APP_URL=https://example.com
ENVIRONMENT=production

# === CORS ===
# Домены админки/сайта (виджет на сторонних сайтах работает независимо).
ALLOWED_ORIGINS=https://example.com,https://www.example.com

# === Платежи (ЮKassa) — нужны для приёма оплаты тарифов ===
# https://yookassa.ru/ → Настройки → Магазин
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# === Почта (уведомления, лиды, email-канал) ===
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_REPLY_TO=
MAIL_SERVER=
MAIL_PORT=465

# === Каналы (опционально, если используешь) ===
# YOOKASSA/почта выше обязательны для монетизации; ниже — по необходимости.
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
# MAX_BOT_TOKEN=

# === Локальная отладка каналов (НЕ ставить на проде — сносит webhook) ===
# TELEGRAM_POLLING_ENABLED=false
# MAX_POLLING_ENABLED=false

# === Опционально ===
# CHAT_PORT=5001
# FLASK_DEBUG=0
# RATE_LIMIT_PER_MIN=20
