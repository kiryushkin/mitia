# ============================================================================
#  ШАБЛОН ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
#  Скопируй в .env и заполни своими значениями.
#  cp .env.example .env
# ============================================================================

# === GigaChat (Сбер) ===
# Получить: https://developers.sber.ru/portal/products/gigachat-api
GIGACHAT_KEY=
AI_PROVIDER=gigachat

# === Альтернативно — OpenAI ===
# OPENAI_KEY=sk-...
# AI_PROVIDER=openai

# === ВКонтакте (нотификации лидов) ===
# Получить токен: https://vkhost.github.io/ (пользовательский) или
# в настройках сообщества: Управление → Работа с API → Создать ключ
VK_TOKEN=
VK_USER_ID=

# === Безопасность ===
# СГЕНЕРИРУЙ свой длинный секрет:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=
SUPERADMIN_MASTER_TOKEN=

# === Сайт ===
SITE_URL=https://example.com

# === CORS ===
ALLOWED_ORIGINS=https://example.com

# === Опционально ===
# CHAT_PORT=5001
# FLASK_DEBUG=0
# RATE_LIMIT_PER_MIN=20
